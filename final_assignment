BEGIN;

DELETE FROM hotel_booking.bookings
WHERE status = 'cancelled'
RETURNING booking_id, guest_id;

ROLLBACK;

-- PART 6: GRANT / REVOKE

DO $$
BEGIN
    IF EXISTS (
        SELECT FROM pg_roles
        WHERE rolname = 'hotel_readonly'
    ) THEN

        REASSIGN OWNED BY hotel_readonly TO CURRENT_USER;
        DROP OWNED BY hotel_readonly;
        DROP ROLE hotel_readonly;

    END IF;

    IF EXISTS (
        SELECT FROM pg_roles
        WHERE rolname = 'hotel_writer'
    ) THEN

        REASSIGN OWNED BY hotel_writer TO CURRENT_USER;
        DROP OWNED BY hotel_writer;
        DROP ROLE hotel_writer;

    END IF;
END $$;

CREATE ROLE hotel_readonly;
CREATE ROLE hotel_writer;

GRANT USAGE ON SCHEMA hotel_booking
TO hotel_readonly, hotel_writer;

GRANT SELECT
ON ALL TABLES IN SCHEMA hotel_booking
TO hotel_readonly;

GRANT INSERT, UPDATE
ON hotel_booking.bookings
TO hotel_writer;

-- hotel_writer should not modify existing bookings
-- corrections are handled by managers only
REVOKE UPDATE
ON hotel_booking.bookings
FROM hotel_writer;
