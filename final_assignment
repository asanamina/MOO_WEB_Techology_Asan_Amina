CREATE SCHEMA IF NOT EXISTS hotel_booking;
DROP TABLE IF EXISTS
    hotel_booking.booking_services,
    hotel_booking.booking_rooms,
    hotel_booking.payments,
    hotel_booking.bookings,
    hotel_booking.services,
    hotel_booking.rooms,
    hotel_booking.room_types,
    hotel_booking.hotels,
    hotel_booking.employees,
    hotel_booking.departments,
    hotel_booking.guests
CASCADE;

CREATE TABLE IF NOT EXISTS hotel_booking.guests (
    guest_id SERIAL PRIMARY KEY,

    -- guest email must be unique
    email VARCHAR(120) UNIQUE NOT NULL,

    -- full name is required
    full_name VARCHAR(150) NOT NULL,

    -- gender restricted to valid options
    gender VARCHAR(10)
    CHECK (gender IN ('M','F','Other')),

    phone_number VARCHAR(15),

    birth_date DATE,

    status VARCHAR(20) DEFAULT 'active',

    created_at TIMESTAMP DEFAULT NOW()
);

CREATE TABLE IF NOT EXISTS hotel_booking.hotels (
    hotel_id SERIAL PRIMARY KEY,

    name VARCHAR(150) NOT NULL,

    city VARCHAR(100) NOT NULL,

    rating NUMERIC(2,1)
    CHECK (rating >= 0)
);

CREATE TABLE IF NOT EXISTS hotel_booking.room_types (
    room_type_id SERIAL PRIMARY KEY,

    type_name VARCHAR(50) UNIQUE NOT NULL,

    nightly_rate NUMERIC(10,2)
    CHECK (nightly_rate >= 0)
);

CREATE TABLE IF NOT EXISTS hotel_booking.rooms (
    room_id SERIAL PRIMARY KEY,

    hotel_id INT NOT NULL
    REFERENCES hotel_booking.hotels(hotel_id)
    ON DELETE CASCADE,

    room_type_id INT NOT NULL
    REFERENCES hotel_booking.room_types(room_type_id)
    ON DELETE RESTRICT,

    room_number VARCHAR(20) UNIQUE NOT NULL,

    floor INT CHECK (floor >= 0),

    room_status VARCHAR(20)
    DEFAULT 'available'
    CHECK (room_status IN ('available','occupied','maintenance'))
);

CREATE TABLE IF NOT EXISTS hotel_booking.bookings (
    booking_id SERIAL PRIMARY KEY,

    guest_id INT NOT NULL
    REFERENCES hotel_booking.guests(guest_id)
    ON DELETE RESTRICT,

    booking_date DATE NOT NULL
    CHECK (booking_date > DATE '2026-01-01'),

    check_in DATE NOT NULL,

    check_out DATE NOT NULL,

    status VARCHAR(20)
    CHECK (status IN ('pending','confirmed','cancelled')),

    total_amount NUMERIC(12,2)
    DEFAULT 0
);

CREATE TABLE IF NOT EXISTS hotel_booking.booking_rooms (
    booking_room_id SERIAL PRIMARY KEY,

    booking_id INT NOT NULL
    REFERENCES hotel_booking.bookings(booking_id)
    ON DELETE CASCADE,

    room_id INT NOT NULL
    REFERENCES hotel_booking.rooms(room_id)
    ON DELETE RESTRICT,

    nights INT NOT NULL
    CHECK (nights > 0),

    nightly_rate NUMERIC(10,2)
    CHECK (nightly_rate >= 0),

    total_price NUMERIC(12,2)
    GENERATED ALWAYS AS (nights * nightly_rate) STORED
);

CREATE TABLE IF NOT EXISTS hotel_booking.services (
    service_id SERIAL PRIMARY KEY,

    service_name VARCHAR(100) UNIQUE NOT NULL,

    service_price NUMERIC(10,2)
    CHECK (service_price >= 0)
);

CREATE TABLE IF NOT EXISTS hotel_booking.booking_services (
    booking_service_id SERIAL PRIMARY KEY,

    booking_id INT NOT NULL
    REFERENCES hotel_booking.bookings(booking_id)
    ON DELETE CASCADE,

    service_id INT NOT NULL
    REFERENCES hotel_booking.services(service_id)
    ON DELETE RESTRICT,

    quantity INT
    CHECK (quantity > 0)
);

CREATE TABLE IF NOT EXISTS hotel_booking.payments (
    payment_id SERIAL PRIMARY KEY,

    booking_id INT NOT NULL
    REFERENCES hotel_booking.bookings(booking_id)
    ON DELETE CASCADE,

    payment_date DATE NOT NULL,

    amount NUMERIC(10,2)
    CHECK (amount >= 0),

    payment_method VARCHAR(20)
    CHECK (payment_method IN ('cash','card','online'))
);

CREATE TABLE IF NOT EXISTS hotel_booking.departments (
    department_id SERIAL PRIMARY KEY,

    department_name VARCHAR(100) UNIQUE NOT NULL
);

CREATE TABLE IF NOT EXISTS hotel_booking.employees (
    employee_id SERIAL PRIMARY KEY,

    department_id INT NOT NULL
    REFERENCES hotel_booking.departments(department_id)
    ON DELETE SET NULL,

    full_name VARCHAR(150) NOT NULL,

    position VARCHAR(100) NOT NULL,

    salary NUMERIC(10,2)
    CHECK (salary >= 0)
);

