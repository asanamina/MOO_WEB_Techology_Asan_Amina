-- PART 5: UPDATE
-- premium guests receive loyalty points
UPDATE hotel_booking.guests
SET loyalty_points = 500
WHERE guest_id IN (
    SELECT guest_id
    FROM hotel_booking.bookings
    WHERE total_amount > 100000
);

-- update booking totals from room totals
UPDATE hotel_booking.bookings b
SET total_amount = sub.new_total
FROM (
    SELECT booking_id,
           SUM(total_price) AS new_total
    FROM hotel_booking.booking_rooms
    GROUP BY booking_id
) sub
WHERE b.booking_id = sub.booking_id;

